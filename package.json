{
  "name": "tafweej-data-fusion",
  "version": "1.0.0",
  "description": "Real-Time Operational Intelligence Platform for Pilgrim Movement Management",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "@elastic/elasticsearch": "^9.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
